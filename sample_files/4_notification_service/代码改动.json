                                     "package com.example.notification;",
                                     "",
                                     "import java.util.List;",
                                     "import java.util.Date;",
                                     "import java.util.Random;",
                                     "import java.util.stream.Collectors;",
                                     "",
                                     "public class NotificationService {",
                                     "",
                                     "    private EmailProvider emailProvider;",
                                     "    private SMSProvider smsProvider;",
                                     "    private PushProvider pushProvider;",
                                     "    private NotificationRepository notificationRepository;",
                                     "    private ScheduledTaskRepository taskRepository;",
                                     "",
                                     "    public String sendEmail(String to, String subject, String content) {",
                                     "        if (to == null || !to.matches(\"^[A-Za-z0-9+_.-]+@(.+)$\")) {",
                                     "            throw new IllegalArgumentException(\"Invalid email address\");",
                                     "        }",
                                     "        if (subject == null || subject.isEmpty()) {",
                                     "            throw new IllegalArgumentException(\"Subject cannot be empty\");",
                                     "        }",
                                     "        if (content == null || content.isEmpty()) {",
                                     "            throw new IllegalArgumentException(\"Content cannot be empty\");",
                                     "        }",
                                     "",
                                     "        Notification notification = new Notification();",
                                     "        notification.setType(\"email\");",
                                     "        notification.setTo(to);",
                                     "        notification.setSubject(subject);",
                                     "        notification.setContent(content);",
                                     "        notification.setStatus(\"sending\");",
                                     "        notification.setCreatedAt(new Date());",
                                     "",
                                     "        try {",
                                     "            emailProvider.send(to, subject, content);",
                                     "            notification.setStatus(\"sent\");",
                                     "            notification.setSentAt(new Date());",
                                     "        } catch (Exception e) {",
                                     "            notification.setStatus(\"failed\");",
                                     "            notification.setErrorMessage(e.getMessage());",
                                     "        }",
                                     "",
                                     "        return notificationRepository.save(notification).getId();",
                                     "    }",
                                     "",
                                     "    public String sendSMS(String phoneNumber, String content) {",
                                     "        if (phoneNumber == null || !phoneNumber.matches(\"^1[3-9]\\\\d{9}$\")) {",
                                     "            throw new IllegalArgumentException(\"Invalid phone number format\");",
                                     "        }",
                                     "        if (content == null || content.isEmpty()) {",
                                     "            throw new IllegalArgumentException(\"Content cannot be empty\");",
                                     "        }",
                                     "        if (content.length() > 500) {",
                                     "            throw new IllegalArgumentException(\"SMS content too long\");",
                                     "        }",
                                     "",
                                     "        Notification notification = new Notification();",
                                     "        notification.setType(\"sms\");",
                                     "        notification.setTo(phoneNumber);",
                                     "        notification.setContent(content);",
                                     "        notification.setStatus(\"sending\");",
                                     "",
                                     "        try {",
                                     "            smsProvider.send(phoneNumber, content);",
                                     "            notification.setStatus(\"sent\");",
                                     "            notification.setSentAt(new Date());",
                                     "        } catch (Exception e) {",
                                     "            notification.setStatus(\"failed\");",
                                     "        }",
                                     "",
                                     "        return notificationRepository.save(notification).getId();",
                                     "    }",
                                     "",
                                     "    public String sendPush(Long userId, String title, String content) {",
                                     "        if (userId == null) {",
                                     "            throw new IllegalArgumentException(\"User ID cannot be null\");",
                                     "        }",
                                     "        if (content == null || content.isEmpty()) {",
                                     "            throw new IllegalArgumentException(\"Content cannot be empty\");",
                                     "        }",
                                     "",
                                     "        Notification notification = new Notification();",
                                     "        notification.setType(\"push\");",
                                     "        notification.setUserId(userId);",
                                     "        notification.setTitle(title);",
                                     "        notification.setContent(content);",
                                     "        notification.setStatus(\"sending\");",
                                     "",
                                     "        try {",
                                     "            pushProvider.send(userId, title, content);",
                                     "            notification.setStatus(\"sent\");",
                                     "            notification.setSentAt(new Date());",
                                     "        } catch (Exception e) {",
                                     "            notification.setStatus(\"failed\");",
                                     "        }",
                                     "",
                                     "        return notificationRepository.save(notification).getId();",
                                     "    }",
                                     "",
                                     "    public BatchSendResult batchSend(List<String> recipients, String type, String subject, String content) {",
                                     "        List<String> successList = recipients.stream()",
                                     "            .filter(r -> {",
                                     "                try {",
                                     "                    if (\"email\".equals(type)) {",
                                     "                        sendEmail(r, subject, content);",
                                     "                    } else if (\"sms\".equals(type)) {",
                                     "                        sendSMS(r, content);",
                                     "                    }",
                                     "                    return true;",
                                     "                } catch (Exception e) {",
                                     "                    return false;",
                                     "                }",
                                     "            })",
                                     "            .collect(Collectors.toList());",
                                     "",
                                     "        List<String> failedList = recipients.stream()",
                                     "            .filter(r -> !successList.contains(r))",
                                     "            .collect(Collectors.toList());",
                                     "",
                                     "        BatchSendResult result = new BatchSendResult();",
                                     "        result.setSuccessCount(successList.size());",
                                     "        result.setFailedCount(failedList.size());",
                                     "        result.setFailedRecipients(failedList);",
                                     "        return result;",
                                     "    }",
                                     "",
                                     "    public String getNotificationStatus(String notificationId) {",
                                     "        Notification notification = notificationRepository.findById(notificationId);",
                                     "        if (notification == null) {",
                                     "            throw new RuntimeException(\"Notification not found\");",
                                     "        }",
                                     "        return notification.getStatus();",
                                     "    }",
                                     "",
                                     "    public String sendVerificationCode(String phoneNumber) {",
                                     "        String code = String.format(\"%06d\", new Random().nextInt(1000000));",
                                     "        String content = \"Your verification code is: \" + code + \", valid for 5 minutes.\";",
                                     "",
                                     "        String notificationId = sendSMS(phoneNumber, content);",
                                     "",
                                     "        VerificationCode verificationCode = new VerificationCode();",
                                     "        verificationCode.setPhoneNumber(phoneNumber);",
                                     "        verificationCode.setCode(code);",
                                     "        verificationCode.setExpiredAt(new Date(System.currentTimeMillis() + 5 * 60 * 1000));",
                                     "        verificationCode.setNotificationId(notificationId);",
                                     "",
                                     "        return notificationRepository.saveVerificationCode(verificationCode).getId();",
                                     "    }",
                                     "",
                                     "    public String scheduleNotification(String type, String recipient, String content, Date scheduledTime) {",
                                     "        if (scheduledTime == null) {",
                                     "            throw new IllegalArgumentException(\"Scheduled time cannot be null\");",
                                     "        }",
                                     "        if (scheduledTime.before(new Date())) {",
                                     "            throw new IllegalArgumentException(\"Scheduled time must be in the future\");",
                                     "        }",
                                     "",
                                     "        ScheduledTask task = new ScheduledTask();",
                                     "        task.setType(type);",
                                     "        task.setRecipient(recipient);",
                                     "        task.setContent(content);",
                                     "        task.setScheduledTime(scheduledTime);",
                                     "        task.setStatus(\"pending\");",
                                     "        task.setCreatedAt(new Date());",
                                     "",
                                     "        return taskRepository.save(task).getId();",
                                     "    }",
                                     "}"
                                 ]
                             ],
