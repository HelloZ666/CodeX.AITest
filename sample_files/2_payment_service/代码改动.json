                                     "package com.example.payment;",
                                     "",
                                     "import java.math.BigDecimal;",
                                     "import java.util.Date;",
                                     "import java.util.UUID;",
                                     "",
                                     "public class PaymentService {",
                                     "",
                                     "    private PaymentRepository paymentRepository;",
                                     "    private OrderService orderService;",
                                     "    private NotificationService notificationService;",
                                     "    private PaymentGateway paymentGateway;",
                                     "",
                                     "    public Payment processPayment(Long orderId, BigDecimal amount, String paymentMethod) {",
                                     "        if (amount == null || amount.compareTo(BigDecimal.ZERO) <= 0) {",
                                     "            throw new IllegalArgumentException(\"Amount must be greater than zero\");",
                                     "        }",
                                     "        if (paymentMethod == null || paymentMethod.isEmpty()) {",
                                     "            throw new IllegalArgumentException(\"Payment method is required\");",
                                     "        }",
                                     "",
                                     "        Order order = orderService.getOrderById(orderId);",
                                     "        if (order.getStatus().equals(\"paid\")) {",
                                     "            throw new IllegalStateException(\"Order already paid\");",
                                     "        }",
                                     "",
                                     "        Payment payment = new Payment();",
                                     "        payment.setOrderId(orderId);",
                                     "        payment.setAmount(amount);",
                                     "        payment.setPaymentMethod(paymentMethod);",
                                     "        payment.setStatus(\"pending\");",
                                     "        payment.setPaymentNo(\"PAY\" + UUID.randomUUID().toString().substring(0, 8).toUpperCase());",
                                     "        payment.setCreatedAt(new Date());",
                                     "",
                                     "        Payment result = paymentGateway.process(payment);",
                                     "        if (result.getStatus().equals(\"success\")) {",
                                     "            payment.setStatus(\"success\");",
                                     "            payment.setPaidAt(new Date());",
                                     "            orderService.updateOrderStatus(orderId, \"paid\");",
                                     "            notificationService.notifyPaymentSuccess(orderId);",
                                     "        } else {",
                                     "            payment.setStatus(\"failed\");",
                                     "            payment.setErrorMessage(result.getErrorMessage());",
                                     "        }",
                                     "",
                                     "        return paymentRepository.save(payment);",
                                     "    }",
                                     "",
                                     "    public Refund refundPayment(Long paymentId, String reason) {",
                                     "        Payment payment = paymentRepository.findById(paymentId);",
                                     "        if (payment == null) {",
                                     "            throw new RuntimeException(\"Payment not found\");",
                                     "        }",
                                     "        if (!\"success\".equals(payment.getStatus())) {",
                                     "            throw new IllegalStateException(\"Can only refund successful payments\");",
                                     "        }",
                                     "        if (payment.getRefundedAt() != null) {",
                                     "            throw new IllegalStateException(\"Payment already refunded\");",
                                     "        }",
                                     "",
                                     "        Refund refund = new Refund();",
                                     "        refund.setPaymentId(paymentId);",
                                     "        refund.setAmount(payment.getAmount());",
                                     "        refund.setReason(reason);",
                                     "        refund.setStatus(\"processing\");",
                                     "        refund.setRefundNo(\"REF\" + UUID.randomUUID().toString().substring(0, 8).toUpperCase());",
                                     "",
                                     "        Refund result = paymentGateway.refund(refund);",
                                     "        if (result.getStatus().equals(\"success\")) {",
                                     "            refund.setStatus(\"success\");",
                                     "            refund.setRefundedAt(new Date());",
                                     "            orderService.updateOrderStatus(payment.getOrderId(), \"refunded\");",
                                     "        }",
                                     "",
                                     "        return paymentRepository.saveRefund(refund);",
                                     "    }",
                                     "",
                                     "    public String getPaymentStatus(Long paymentId) {",
                                     "        Payment payment = paymentRepository.findById(paymentId);",
                                     "        if (payment == null) {",
                                     "            throw new RuntimeException(\"Payment not found\");",
                                     "        }",
                                     "        return payment.getStatus();",
                                     "    }",
                                     "",
                                     "    public void cancelPayment(Long paymentId) {",
                                     "        Payment payment = paymentRepository.findById(paymentId);",
                                     "        if (payment == null) {",
                                     "            throw new RuntimeException(\"Payment not found\");",
                                     "        }",
                                     "        if (!\"pending\".equals(payment.getStatus())) {",
                                     "            throw new IllegalStateException(\"Can only cancel pending payments\");",
                                     "        }",
                                     "        payment.setStatus(\"cancelled\");",
                                     "        paymentRepository.save(payment);",
                                     "    }",
                                     "",
                                     "    public boolean verifyPayment(Long paymentId, String signature) {",
                                     "        Payment payment = paymentRepository.findById(paymentId);",
                                     "        if (payment == null) {",
                                     "            return false;",
                                     "        }",
                                     "        String expectedSignature = paymentGateway.generateSignature(payment);",
                                     "        return expectedSignature.equals(signature);",
                                     "    }",
                                     "",
                                     "    public String createPaymentLink(Long orderId, BigDecimal amount) {",
                                     "        Order order = orderService.getOrderById(orderId);",
                                     "        String paymentNo = \"PAY\" + UUID.randomUUID().toString().substring(0, 8).toUpperCase();",
                                     "        return paymentGateway.createPaymentLink(orderId, amount, paymentNo);",
                                     "    }",
                                     "",
                                     "    public void notifyPaymentSuccess(Long orderId) {",
                                     "        notificationService.sendNotification(orderId, \"payment_success\");",
                                     "    }",
                                     "}"
                                 ]
                             ],
