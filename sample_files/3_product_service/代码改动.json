                                     "package com.example.product;",
                                     "",
                                     "import java.math.BigDecimal;",
                                     "import java.util.List;",
                                     "import java.util.Date;",
                                     "",
                                     "public class ProductService {",
                                     "",
                                     "    private ProductRepository productRepository;",
                                     "    private ReviewRepository reviewRepository;",
                                     "    private SearchService searchService;",
                                     "",
                                     "    public Product createProduct(String name, BigDecimal price, Integer stock, String description) {",
                                     "        if (name == null || name.isEmpty()) {",
                                     "            throw new IllegalArgumentException(\"Product name cannot be empty\");",
                                     "        }",
                                     "        if (price == null || price.compareTo(BigDecimal.ZERO) < 0) {",
                                     "            throw new IllegalArgumentException(\"Price cannot be negative\");",
                                     "        }",
                                     "        if (stock == null || stock < 0) {",
                                     "            throw new IllegalArgumentException(\"Stock cannot be negative\");",
                                     "        }",
                                     "",
                                     "        Product product = new Product();",
                                     "        product.setName(name);",
                                     "        product.setPrice(price);",
                                     "        product.setStock(stock);",
                                     "        product.setDescription(description);",
                                     "        product.setStatus(stock > 0 ? \"active\" : \"out_of_stock\");",
                                     "        product.setCreatedAt(new Date());",
                                     "",
                                     "        Product saved = productRepository.save(product);",
                                     "        searchService.indexProduct(saved);",
                                     "        return saved;",
                                     "    }",
                                     "",
                                     "    public Product updateProduct(Long id, String name, BigDecimal price, String description) {",
                                     "        Product product = productRepository.findById(id);",
                                     "        if (product == null) {",
                                     "            throw new RuntimeException(\"Product not found\");",
                                     "        }",
                                     "        if (name != null && !name.isEmpty()) {",
                                     "            product.setName(name);",
                                     "        }",
                                     "        if (price != null) {",
                                     "            product.setPrice(price);",
                                     "        }",
                                     "        if (description != null) {",
                                     "            product.setDescription(description);",
                                     "        }",
                                     "        product.setUpdatedAt(new Date());",
                                     "",
                                     "        Product updated = productRepository.save(product);",
                                     "        searchService.updateProduct(updated);",
                                     "        return updated;",
                                     "    }",
                                     "",
                                     "    public void deleteProduct(Long id) {",
                                     "        Product product = productRepository.findById(id);",
                                     "        if (product == null) {",
                                     "            throw new RuntimeException(\"Product not found\");",
                                     "        }",
                                     "        product.setStatus(\"deleted\");",
                                     "        product.setDeletedAt(new Date());",
                                     "        productRepository.save(product);",
                                     "        searchService.deleteProduct(id);",
                                     "    }",
                                     "",
                                     "    public Product getProductById(Long id) {",
                                     "        Product product = productRepository.findById(id);",
                                     "        if (product == null || \"deleted\".equals(product.getStatus())) {",
                                     "            throw new RuntimeException(\"Product not found\");",
                                     "        }",
                                     "        return product;",
                                     "    }",
                                     "",
                                     "    public List<Product> listProducts(int page, int size, String category) {",
                                     "        if (page < 0 || size <= 0) {",
                                     "            throw new IllegalArgumentException(\"Invalid pagination parameters\");",
                                     "        }",
                                     "        return productRepository.findByCategory(category, page, size);",
                                     "    }",
                                     "",
                                     "    public void updateStock(Long id, int quantity, boolean isIncrease) {",
                                     "        Product product = productRepository.findById(id);",
                                     "        if (product == null) {",
                                     "            throw new RuntimeException(\"Product not found\");",
                                     "        }",
                                     "",
                                     "        int newStock;",
                                     "        if (isIncrease) {",
                                     "            newStock = product.getStock() + quantity;",
                                     "        } else {",
                                     "            newStock = product.getStock() - quantity;",
                                     "            if (newStock < 0) {",
                                     "                throw new RuntimeException(\"Insufficient stock\");",
                                     "            }",
                                     "        }",
                                     "",
                                     "        product.setStock(newStock);",
                                     "        product.setStatus(newStock > 0 ? \"active\" : \"out_of_stock\");",
                                     "        product.setUpdatedAt(new Date());",
                                     "        productRepository.save(product);",
                                     "    }",
                                     "",
                                     "    public List<Product> searchProducts(String keyword, int page, int size) {",
                                     "        return searchService.search(keyword, page, size);",
                                     "    }",
                                     "",
                                     "    public ProductDetail getProductDetail(Long id) {",
                                     "        Product product = getProductById(id);",
                                     "        List<Review> reviews = reviewRepository.findByProductId(id);",
                                     "        double avgRating = reviews.stream()",
                                     "            .mapToInt(Review::getRating)",
                                     "            .average()",
                                     "            .orElse(0.0);",
                                     "",
                                     "        ProductDetail detail = new ProductDetail();",
                                     "        detail.setProduct(product);",
                                     "        detail.setReviews(reviews);",
                                     "        detail.setAverageRating(avgRating);",
                                     "        return detail;",
                                     "    }",
                                     "}"
                                 ]
