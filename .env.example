# 环境变量示例
# 推荐把本文件复制到“项目同级的 runtime 目录”里，例如：
# D:\CodeXAI\CodeX.AITest.runtime\.env

# AI 提供方
# 可选值：
# - deepseek：使用公网 DeepSeek OpenAI 兼容接口
# - internal：使用公司内部私有大模型接口
AI_PROVIDER=deepseek

# AI 展示名称（可选）
# 未配置时：
# - deepseek -> DeepSeek
# - internal -> 公司内部大模型
# AI_PROVIDER_LABEL=公司内部大模型

# DeepSeek 配置（当 AI_PROVIDER=deepseek 时生效）
# 必须替换成真实可用的 Key，不能直接保留示例占位值 your-deepseek-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
# 可选，默认 deepseek-chat
# AI_MODEL_NAME=deepseek-chat

# 公司内部大模型配置（当 AI_PROVIDER=internal 时生效）
# INTERNAL_LLM_API_URL=http://29.20.1.40/chatgpt/chatgpt/chat/completions
# INTERNAL_LLM_APP_TOKEN=replace-with-real-app-token
# INTERNAL_LLM_APP_ID=replace-with-real-app-id
# INTERNAL_LLM_MODEL=deepseekr1
# INTERNAL_LLM_P13=测试p13
# INTERNAL_LLM_ORGANIZATION=测试组织
# INTERNAL_LLM_SECOND_LEVEL_ORG=二级部门
# INTERNAL_LLM_BUSI_DEPT=业务部门
# INTERNAL_LLM_TOP_P=0.7
# INTERNAL_LLM_TOP_K=50
# INTERNAL_LLM_BIZ_NO_PREFIX=AITEST

# 运行时目录（可选）
# 不配置时，默认使用“项目同级目录\项目名.runtime”
# APP_RUNTIME_DIR=D:\CodeXAI\CodeX.AITest.runtime

# 数据库与日志（可选）
# 不配置时，默认分别落到：
# DB_PATH=%APP_RUNTIME_DIR%\data\codetestguard.db
# APP_LOG_DIR=%APP_RUNTIME_DIR%\logs
# DB_PATH=D:\CodeXAI\CodeX.AITest.runtime\data\codetestguard.db
# APP_LOG_DIR=D:\CodeXAI\CodeX.AITest.runtime\logs

# 认证
SESSION_SECRET=replace-with-a-random-secret
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_DISPLAY_NAME=系统管理员

# CORS / Cookie
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SAMESITE=lax

# 公司内部账号认证（可选）
# EXTERNAL_AUTH_URL=http://25.7.132.19:31001/loginP13
# EXTERNAL_AUTH_TIMEOUT_MS=10000
